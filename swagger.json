  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "details": {
            "type": "object",
            "description": "Opcional",
            "additionalProperties": { "type": "string" }
          }
        }
      },
      "Role": {
        "type": "string",
        "enum": ["admin", "student", "employee"]
      },
      "UserStatus": {
        "type": "string",
        "enum": ["pending", "rejected", "active", "inactive"]
      },
      "Priority": {
        "type": "string",
        "enum": ["low", "medium", "high"]
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "total": { "type": "integer", "minimum": 0 },
          "page": { "type": "integer", "minimum": 1 },
          "lastPage": { "type": "integer", "minimum": 1 }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "email": { "type": "string", "format": "email" },
          "name": { "type": "string" },
          "status": { "$ref": "#/components/schemas/UserStatus" },
          "role": { "$ref": "#/components/schemas/Role" }
        }
      },
      "UserWithToken": {
        "allOf": [
          { "$ref": "#/components/schemas/User" },
          {
            "type": "object",
            "properties": {
              "token": { "type": "string" }
            }
          }
        ]
      },
      "UserCreate": {
        "type": "object",
        "required": ["email", "name", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "name": { "type": "string", "minLength": 3 },
          "password": { "type": "string", "minLength": 8 }
        }
      },
      "UserLogin": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 8 }
        }
      },
      "UserPatch": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 3 },
          "password": { "type": "string", "minLength": 8 },
          "status": { "$ref": "#/components/schemas/UserStatus" },
          "role": { "$ref": "#/components/schemas/Role" }
        }
      },
      "Status": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "color": { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$" }
        }
      },
      "StatusCreate": {
        "type": "object",
        "required": ["name", "description", "color"],
        "properties": {
          "name": { "type": "string", "minLength": 3, "maxLength": 32 },
          "description": { "type": "string", "minLength": 8, "maxLength": 255 },
          "color": { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$" }
        }
      },
      "StatusPatch": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 3, "maxLength": 32 },
          "description": { "type": "string", "minLength": 8, "maxLength": 255 },
          "color": { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$" }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "color": { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$" }
        }
      },
      "CategoryCreate": {
        "type": "object",
        "required": ["name", "description", "color"],
        "properties": {
          "name": { "type": "string", "minLength": 3, "maxLength": 32 },
          "description": { "type": "string", "minLength": 8, "maxLength": 255 },
          "color": { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$" }
        }
      },
      "CategoryPatch": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 3, "maxLength": 32 },
          "description": { "type": "string", "minLength": 8, "maxLength": 255 },
          "color": { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$" }
        }
      },
      "Building": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "status": { "$ref": "#/components/schemas/UserStatus" },
          "area": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "example": "Polygon" },
              "coordinates": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      },
      "BuildingCreate": {
        "type": "object",
        "required": ["name", "description", "area"],
        "properties": {
          "name": { "type": "string", "minLength": 3 },
          "description": { "type": "string", "minLength": 5 },
          "area": {
            "type": "string",
            "description": "WKT Polygon, ex: POLYGON ((x y, x y, ...))"
          }
        }
      },
      "BuildingPatch": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 3 },
          "description": { "type": "string", "minLength": 5 },
          "area": {
            "type": "string",
            "description": "WKT Polygon, ex: POLYGON ((x y, x y, ...))"
          },
          "status": { "$ref": "#/components/schemas/UserStatus" }
        }
      },
      "IncidentPicture": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "incidentId": { "type": "integer" },
          "pictureUrl": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "Incident": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "userId": { "type": "integer" },
          "shortDescription": { "type": "string" },
          "description": { "type": "string" },
          "buildingId": { "type": "integer" },
          "location": { "type": "string" },
          "priority": { "$ref": "#/components/schemas/Priority" },
          "statusId": { "type": "integer" },
          "categoryId": { "type": "integer" }
        }
      },
      "IncidentSummary": {
        "allOf": [
          { "$ref": "#/components/schemas/Incident" },
          {
            "type": "object",
            "properties": {
              "building": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" },
                  "name": { "type": "string" }
                }
              },
              "category": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" },
                  "name": { "type": "string" },
                  "color": { "type": "string" }
                }
              },
              "status": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" },
                  "name": { "type": "string" },
                  "color": { "type": "string" }
                }
              }
            }
          }
        ]
      },
      "IncidentDetailed": {
        "allOf": [
          { "$ref": "#/components/schemas/Incident" },
          {
            "type": "object",
            "properties": {
              "pictures": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/IncidentPicture" }
              },
              "building": { "$ref": "#/components/schemas/Building" },
              "category": { "$ref": "#/components/schemas/Category" },
              "status": { "$ref": "#/components/schemas/Status" }
            }
          }
        ]
      },
      "IncidentCreated": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "shortDescription": { "type": "string" },
          "description": { "type": "string" },
          "location": { "type": "string" },
          "buildingId": { "type": "integer" },
          "categoryId": { "type": "integer" },
          "pictures": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/IncidentPicture" }
          },
          "building": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" }
            }
          },
          "category": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" }
            }
          }
        }
      },
      "IncidentCreate": {
        "type": "object",
        "required": [
          "shortDescription",
          "description",
          "buildingId",
          "location",
          "categoryId",
          "picturesData",
          "pictures"
        ],
        "properties": {
          "shortDescription": {
            "type": "string",
            "minLength": 5,
            "maxLength": 255
          },
          "description": { "type": "string" },
          "buildingId": { "type": "integer", "minimum": 1 },
          "location": { "type": "string", "minLength": 5, "maxLength": 255 },
          "categoryId": { "type": "integer", "minimum": 1 },
          "picturesData": {
            "type": "string",
            "description": "JSON string de [{title, description?}]"
          },
          "pictures": {
            "type": "array",
            "items": { "type": "string", "format": "binary" },
            "minItems": 1,
            "maxItems": 5
          }
        }
      },
      "IncidentPatch": {
        "type": "object",
        "properties": {
          "shortDescription": {
            "type": "string",
            "minLength": 5,
            "maxLength": 255
          },
          "description": { "type": "string" },
          "location": { "type": "string", "minLength": 5, "maxLength": 255 },
          "priority": { "$ref": "#/components/schemas/Priority" },
          "statusId": { "type": "integer", "minimum": 1 },
          "categoryId": { "type": "integer", "minimum": 1 },
          "buildingId": { "type": "integer", "minimum": 1 }
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "incidentId": { "type": "integer" },
          "userId": { "type": "integer" },
          "comment": { "type": "string" },
          "status": { "$ref": "#/components/schemas/UserStatus" }
        }
      },
      "CommentWithUser": {
        "allOf": [
          { "$ref": "#/components/schemas/Comment" },
          {
            "type": "object",
            "properties": {
              "user": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" },
                  "name": { "type": "string" },
                  "role": { "$ref": "#/components/schemas/Role" }
                }
              }
            }
          }
        ]
      },
      "CommentCreate": {
        "type": "object",
        "required": ["incidentId", "comment"],
        "properties": {
          "incidentId": { "type": "integer", "minimum": 1 },
          "comment": { "type": "string", "minLength": 1, "maxLength": 255 }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Requisicao invalida",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Nao autenticado",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Forbidden": {
        "description": "Acesso negado",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotFound": {
        "description": "Nao encontrado",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "UnprocessableEntity": {
        "description": "Erro de processamento",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "InternalServerError": {
        "description": "Erro interno do servidor",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    }
  }
}
